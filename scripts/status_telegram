#!/bin/bash
export PATH="/home/tone/bin:/home/tone/.local/bin:/usr/local/bin:/usr/bin:/bin"

echo "======================================"
echo "🧠 DASHBOARD PERSONAL"
echo "======================================"
echo ""

/home/tone/bin/system_stats

echo ""
echo "🎬 EMBY"
echo "--------------------------------------"
if command -v embyStatus >/dev/null 2>&1; then
  timeout 15s embyStatus || echo "⚠️ Error o timeout en Emby"
else
  echo "⚠️ embyStatus no encontrado"
fi

echo ""
echo "📦 PAQUETES"
echo "--------------------------------------"
/home/tone/bin/envios_check_cooldown

echo ""
echo "======================================"
echo "✅ Dashboard completado"
echo "======================================"
