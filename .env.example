# Telegram
TELEGRAM_TOKEN=0000000000:dummy-token
TELEGRAM_BOT_TOKEN=0000000000:dummy-token
TELEGRAM_CHAT_ID=000000000

# TMDB
TMDB_API_KEY=tmdb_dummy_api_key

# Emby
EMBY_API_KEY=emby_dummy_api_key
EMBY_URL=http://127.0.0.1:8096
EMBY_HOST=user@example-host
EMBY_PORT=2222
EMBY_WATCH_DIR=/media/Peliculas/Biblioteca/

# Remote library destinations
EMBY_SFTP_ANIME_URL=sftp://user@example-host:2222/media/Peliculas/Biblioteca/Anime
EMBY_SFTP_SERIES_URL=sftp://user@example-host:2222/media/Peliculas/Biblioteca/Series
EMBY_SFTP_MOVIES_URL=sftp://user@example-host:2222/media/Peliculas/Biblioteca/Peliculas

# Optional. Leave empty when using SSH key authentication.
EMBY_SFTP_PASSWORD=
